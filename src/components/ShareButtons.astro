---
const { title, url } = Astro.props;

const t = encodeURIComponent(title);
const u = encodeURIComponent(url);
---

<div class="share-buttons" data-share-url={url}>
	<span class="share-label">Share</span>

	<a href={`https://twitter.com/intent/tweet?text=${t}&url=${u}`} class="share-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on X">
		<span class="share-name">X / Twitter</span>
	</a>

	<a href={`https://t.me/share/url?url=${u}&text=${t}`} class="share-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on Telegram">
		<span class="share-name">Telegram</span>
	</a>

	<a href={`https://www.reddit.com/submit?url=${u}&title=${t}`} class="share-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on Reddit">
		<span class="share-name">Reddit</span>
	</a>

	<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${u}`} class="share-btn" target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
		<span class="share-name">LinkedIn</span>
	</a>

	<button type="button" class="share-btn share-copy" aria-label="Copy link">
		<span class="share-name">Copy link</span>
	</button>
</div>

<style>
	.share-buttons {
		display: flex;
		flex-direction: column;
		gap: 8px;
		align-items: flex-start;
	}
	.share-label {
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-text-subtle);
		margin-bottom: 4px;
	}
	.share-btn {
		display: inline-flex;
		align-items: center;
		padding: 8px 14px;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		color: var(--color-text-muted);
		font-size: 13px;
		font-weight: 500;
		text-decoration: none;
		cursor: pointer;
		font-family: inherit;
		transition: all 150ms ease;
		min-width: 110px;
	}
	.share-btn:hover {
		color: var(--color-text);
		border-color: var(--color-accent);
		background: var(--color-surface-alt);
	}
	.share-btn.copied {
		color: #10b981;
		border-color: #10b981;
	}
	@media (max-width: 900px) {
		.share-buttons {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 6px;
			padding-top: 16px;
			padding-bottom: 16px;
			border-top: 1px solid var(--color-border);
			border-bottom: 1px solid var(--color-border);
			margin-top: 24px;
			margin-bottom: 24px;
		}
		.share-label {
			flex-basis: 100%;
		}
		.share-btn {
			min-width: 0;
			padding: 8px 12px;
			font-size: 12px;
		}
	}
</style>

<script>
	document.querySelectorAll('.share-copy').forEach((btn) => {
		btn.addEventListener('click', function() {
			const container = btn.closest('.share-buttons');
			const shareUrl = container ? container.getAttribute('data-share-url') : window.location.href;
			navigator.clipboard.writeText(shareUrl || window.location.href).then(() => {
				btn.classList.add('copied');
				const label = btn.querySelector('.share-name');
				const original = label ? label.textContent : 'Copy link';
				if (label) label.textContent = 'Copied!';
				setTimeout(() => {
					btn.classList.remove('copied');
					if (label) label.textContent = original;
				}, 2000);
			});
		});
	});
</script>