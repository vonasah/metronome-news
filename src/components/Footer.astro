---
// src/components/Footer.astro
// Footer with X (Twitter) and CoinMarketCap social links
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-top">
      <!-- Brand section -->
      <div class="footer-brand">
        <div class="footer-logo">
          <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-label="Metronome News">
            <defs>
              <linearGradient id="footerLogoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#3b82f6" />
                <stop offset="100%" stop-color="#f97316" />
              </linearGradient>
            </defs>
            <rect width="64" height="64" rx="12" fill="url(#footerLogoGrad)" />
            <path
              d="M20 50 L44 50 L36 14 L28 14 Z"
              fill="none"
              stroke="white"
              stroke-width="3"
              stroke-linejoin="round"
            />
            <line
              x1="32"
              y1="50"
              x2="22"
              y2="22"
              stroke="white"
              stroke-width="3"
              stroke-linecap="round"
            />
            <circle cx="22" cy="22" r="3" fill="white" />
          </svg>
        </div>
        <div class="footer-brand-text">
          <div class="footer-brand-name">Metronome News</div>
          <div class="footer-brand-tagline">Crypto journalism without the hype.</div>
        </div>
      </div>

      <!-- Navigation links -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/rss.xml">RSS</a>
      </nav>

      <!-- Social links -->
      <div class="footer-social" aria-label="Social media">
        <!-- X (Twitter) -->
        <a
          href="https://x.com/Metronome_News"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="Follow Metronome News on X"
          title="Follow on X"
        >
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              fill="currentColor"
            />
          </svg>
        </a>

        <!-- CoinMarketCap -->
        <a
          href="https://coinmarketcap.com/community/profile/metronome_news/"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="Follow Metronome News on CoinMarketCap"
          title="Follow on CoinMarketCap"
        >
          <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Outer circle -->
            <circle cx="16" cy="16" r="14" fill="none" stroke="currentColor" stroke-width="2" />
            <!-- Stylized chart peaks (CMC signature element) -->
            <path
              d="M 8 20 L 12 14 L 16 18 L 20 12 L 24 16"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <!-- Small dot at the highest peak -->
            <circle cx="20" cy="12" r="1.4" fill="currentColor" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <div class="footer-copyright">
        © 2026 Metronome News. All rights reserved.
      </div>
      <div class="footer-disclaimer">
        Independent crypto journalism. No ads. No tracking. No algorithm.
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-secondary, #1e293b);
    border-top: 1px solid var(--color-border, #334155);
    padding: 3rem 1.5rem 2rem 1.5rem;
    margin-top: 4rem;
    color: var(--color-text-secondary, #cbd5e1);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 1fr auto;
    gap: 2rem;
    align-items: start;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border, #334155);
    margin-bottom: 1.5rem;
  }

  /* Brand section */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-logo {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
  }

  .footer-logo svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .footer-brand-text {
    line-height: 1.3;
  }

  .footer-brand-name {
    font-size: 1.1rem;
    font-weight: 800;
    background: linear-gradient(135deg, #3b82f6 0%, #f97316 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    letter-spacing: -0.02em;
  }

  .footer-brand-tagline {
    font-size: 0.78rem;
    color: var(--color-text-tertiary, #94a3b8);
    margin-top: 0.2rem;
  }

  /* Navigation links */
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    align-self: center;
  }

  .footer-nav a {
    color: var(--color-text-secondary, #cbd5e1);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--color-accent, #3b82f6);
  }

  /* Social links */
  .footer-social {
    display: flex;
    gap: 0.6rem;
    align-self: center;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--color-bg-primary, #0f172a);
    border: 1px solid var(--color-border, #334155);
    color: var(--color-text-secondary, #cbd5e1);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .social-link:hover {
    background: linear-gradient(135deg, #3b82f6 0%, #f97316 100%);
    color: white;
    border-color: transparent;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
  }

  .social-link svg {
    width: 18px;
    height: 18px;
    display: block;
  }

  /* Footer bottom */
  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-text-tertiary, #94a3b8);
  }

  .footer-disclaimer {
    text-align: right;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .site-footer {
      padding: 2rem 1rem 1.5rem 1rem;
    }

    .footer-top {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      text-align: center;
    }

    .footer-brand {
      justify-content: center;
    }

    .footer-nav {
      justify-content: center;
    }

    .footer-social {
      justify-content: center;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 0.4rem;
    }

    .footer-disclaimer {
      text-align: center;
    }
  }
</style>
