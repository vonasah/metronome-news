---
import { getCollection } from 'astro:content';

interface Props {
	currentId: string;
	category: string;
	limit?: number;
}

const { currentId, category, limit = 3 } = Astro.props;

// Get all other articles in the same category
const allArticles = await getCollection('articles', ({ data }) => !data.draft);

const related = allArticles
	.filter((a) => a.data.category === category && a.id !== currentId)
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, limit);

// Format category name for display
const categoryTitle = category
	.split('-')
	.map((w) => w.charAt(0).toUpperCase() + w.slice(1))
	.join(' ');

function formatDate(date) {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	});
}
---

{related.length > 0 && (
	<section class="related-section">
		<h2 class="related-heading">More in {categoryTitle}</h2>
		<div class="related-grid">
			{related.map((article) => {
				const href = "/article/" + article.id;
				return (
					<a href={href} class="related-card">
						{article.data.image && (
							<div class="related-image">
								<img
									src={article.data.image}
									alt={article.data.imageAlt || article.data.title}
									loading="lazy"
								/>
							</div>
						)}
						<div class="related-body">
							<h3 class="related-title">{article.data.title}</h3>
							<div class="related-meta">
								<span>By {article.data.author}</span>
								<span class="dot">·</span>
								<time datetime={article.data.publishDate.toISOString()}>
									{formatDate(article.data.publishDate)}
								</time>
							</div>
						</div>
					</a>
				);
			})}
		</div>
	</section>
)}

<style>
	.related-section {
		margin-top: 4rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--color-border);
	}

	.related-heading {
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-text-subtle);
		margin-bottom: 1.5rem;
	}

	.related-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	.related-card {
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.75rem;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: transform 0.15s, border-color 0.15s;
	}
	.related-card:hover {
		transform: translateY(-2px);
		border-color: var(--color-accent);
	}

	.related-image {
		aspect-ratio: 16 / 9;
		background: var(--color-surface-alt);
		overflow: hidden;
	}
	.related-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s;
	}
	.related-card:hover .related-image img {
		transform: scale(1.04);
	}

	.related-body {
		padding: 1rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.related-title {
		font-size: 1rem;
		line-height: 1.35;
		font-weight: 700;
		color: var(--color-text);
		margin-bottom: 0.6rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.related-meta {
		font-size: 0.75rem;
		color: var(--color-text-subtle);
		margin-top: auto;
	}
	.related-meta .dot {
		margin-inline: 0.3rem;
		opacity: 0.5;
	}

	@media (max-width: 768px) {
		.related-grid {
			grid-template-columns: 1fr;
			gap: 0.75rem;
		}
		.related-section {
			margin-top: 2.5rem;
			padding-top: 1.5rem;
		}
	}
</style>