---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../content.config';

export async function getStaticPaths() {
	const allArticles = await getCollection('articles', ({ data }) => !data.draft);

	return CATEGORIES.map((category) => {
		const articles = allArticles
			.filter((a) => a.data.category === category)
			.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

		return {
			params: { category },
			props: { category, articles },
		};
	});
}

interface Props {
	category: string;
	articles: Awaited<ReturnType<typeof getCollection<'articles'>>>;
}

const { category, articles } = Astro.props;

const categoryTitle = category
	.split('-')
	.map((w) => w.charAt(0).toUpperCase() + w.slice(1))
	.join(' ');

function formatDate(date) {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	});
}
---

<Layout
	title={categoryTitle + " — Metronome News"}
	description={"Latest " + categoryTitle + " news, analysis, and commentary from Metronome News."}
>
	<main class="container category-page">
		<nav class="breadcrumbs" aria-label="Breadcrumb">
			<a href="/">Home</a>
			<span class="sep">›</span>
			<span class="current">{categoryTitle}</span>
		</nav>

		<header class="category-header">
			<div class="category-badge">{category}</div>
			<h1>{categoryTitle}</h1>
			<p class="count">
				{articles.length === 0
					? "No articles yet — check back soon."
					: articles.length + " article" + (articles.length === 1 ? '' : 's')}
			</p>
		</header>

		{articles.length > 0 ? (
			<div class="article-grid">
				{articles.map((article) => {
					const href = "/article/" + article.id;
					return (
						<a href={href} class="article-card">
							{article.data.image && (
								<div class="card-image">
									<img
										src={article.data.image}
										alt={article.data.imageAlt || article.data.title}
										loading="lazy"
									/>
								</div>
							)}
							<div class="card-body">
								<div class="card-category">{categoryTitle}</div>
								<h2 class="card-title">{article.data.title}</h2>
								<p class="card-description">{article.data.description}</p>
								<div class="card-meta">
									<span>By {article.data.author}</span>
									<span class="dot">·</span>
									<time datetime={article.data.publishDate.toISOString()}>
										{formatDate(article.data.publishDate)}
									</time>
								</div>
							</div>
						</a>
					);
				})}
			</div>
		) : (
			<div class="empty-state">
				<p>🎵 No articles in this category yet.</p>
				<a href="/" class="back-link">← Back to home</a>
			</div>
		)}
	</main>
</Layout>

<style>
	.category-page {
		padding-block: 2.5rem 5rem;
		max-width: 1100px;
	}

	.breadcrumbs {
		font-size: 0.85rem;
		color: var(--color-text-subtle);
		margin-bottom: 2rem;
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	.breadcrumbs a {
		color: var(--color-text-muted);
		text-decoration: none;
	}
	.breadcrumbs a:hover {
		color: var(--color-accent);
	}
	.breadcrumbs .sep {
		opacity: 0.4;
	}
	.breadcrumbs .current {
		color: var(--color-text);
		font-weight: 500;
	}

	.category-header {
		margin-bottom: 3rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}
	.category-badge {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: 0.75rem;
	}
	.category-header h1 {
		font-size: clamp(2rem, 4vw, 2.75rem);
		letter-spacing: -0.02em;
		margin-bottom: 0.5rem;
		color: var(--color-text);
	}
	.count {
		color: var(--color-text-subtle);
		font-size: 0.95rem;
	}

	.article-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.25rem;
	}

	.article-card {
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.85rem;
		text-decoration: none;
		color: inherit;
		overflow: hidden;
		transition: border-color 0.15s, transform 0.15s;
	}
	.article-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
	}

	.card-image {
		aspect-ratio: 16 / 9;
		background: var(--color-surface-alt);
		overflow: hidden;
	}
	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s;
	}
	.article-card:hover .card-image img {
		transform: scale(1.04);
	}

	.card-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.card-category {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: 0.7rem;
	}
	.card-title {
		font-size: 1.15rem;
		line-height: 1.35;
		margin-bottom: 0.6rem;
		color: var(--color-text);
		font-weight: 700;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.card-description {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		line-height: 1.5;
		margin-bottom: 1rem;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.card-meta {
		font-size: 0.8rem;
		color: var(--color-text-subtle);
		margin-top: auto;
	}
	.card-meta .dot {
		margin-inline: 0.35rem;
		opacity: 0.5;
	}

	.empty-state {
		text-align: center;
		padding: 3rem 2rem;
		background: var(--color-surface);
		border: 1px dashed var(--color-border);
		border-radius: 0.85rem;
		color: var(--color-text-muted);
	}
	.empty-state .back-link {
		display: inline-block;
		margin-top: 1rem;
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 500;
	}
	.empty-state .back-link:hover {
		text-decoration: underline;
	}
	/* Mobile: compact cards */
	@media (max-width: 640px) {
		.category-page {
			padding-block: 1.5rem 3rem;
		}
		.category-header {
			margin-bottom: 2rem;
		}
		.article-grid {
			grid-template-columns: 1fr;
			gap: 0.75rem;
		}
		.article-card {
			flex-direction: row;
			padding: 0;
			overflow: hidden;
			min-height: 100px;
		}
		.card-image {
			flex-shrink: 0;
			width: 120px;
			aspect-ratio: auto;
			height: auto;
		}
		.card-body {
			padding: 0.85rem 1rem;
			gap: 0.3rem;
			flex: 1;
		}
		.card-category {
			font-size: 0.65rem;
			margin-bottom: 0.3rem;
		}
		.card-title {
			font-size: 0.95rem;
			-webkit-line-clamp: 2;
			margin-bottom: 0.3rem;
		}
		.card-description {
			display: none;
		}
		.card-meta {
			font-size: 0.7rem;
		}
	}
</style>