---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../content.config';

// Генерируем по одной странице на каждую категорию
export async function getStaticPaths() {
	const allArticles = await getCollection('articles', ({ data }) => !data.draft);

	return CATEGORIES.map((category) => {
		const articles = allArticles
			.filter((a) => a.data.category === category)
			.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

		return {
			params: { category },
			props: { category, articles },
		};
	});
}

interface Props {
	category: string;
	articles: Awaited<ReturnType<typeof getCollection<'articles'>>>;
}

const { category, articles } = Astro.props;

// Красивое имя категории: "market-analysis" → "Market Analysis"
const categoryTitle = category
	.split('-')
	.map((w) => w.charAt(0).toUpperCase() + w.slice(1))
	.join(' ');
---

<Layout
	title={`${categoryTitle} — Metronome News`}
	description={`Latest ${categoryTitle} news, analysis, and commentary from Metronome News.`}
>
	<main class="container category-page">
		<!-- Breadcrumbs -->
		<nav class="breadcrumbs" aria-label="Breadcrumb">
			<a href="/">Home</a>
			<span class="sep">›</span>
			<span class="current">{categoryTitle}</span>
		</nav>

		<header class="category-header">
			<div class="category-badge">{category}</div>
			<h1>{categoryTitle}</h1>
			<p class="count">
				{articles.length === 0
					? 'No articles yet — check back soon.'
					: `${articles.length} article${articles.length === 1 ? '' : 's'}`}
			</p>
		</header>

		{articles.length > 0 ? (
			<ul class="article-list">
				{articles.map((article) => (
					<li class="article-card">
						<h2>
							<a href={`/article/${article.id}`}>{article.data.title}</a>
						</h2>
						<p class="desc">{article.data.description}</p>
						<div class="meta">
							by <strong>{article.data.author}</strong>
							<span class="dot">·</span>
							<time datetime={article.data.publishDate.toISOString()}>
								{article.data.publishDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'short',
									day: 'numeric',
								})}
							</time>
						</div>
					</li>
				))}
			</ul>
		) : (
			<div class="empty-state">
				<p>🎵 No articles in this category yet.</p>
				<a href="/" class="back-link">← Back to home</a>
			</div>
		)}
	</main>
</Layout>

<style>
	.category-page {
		padding-block: 3rem 5rem;
		max-width: 900px;
	}

	.breadcrumbs {
		font-size: 0.85rem;
		color: var(--color-text-subtle);
		margin-bottom: 2rem;
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	.breadcrumbs a { color: var(--color-text-muted); }
	.breadcrumbs a:hover { color: var(--color-accent); }
	.breadcrumbs .sep { opacity: 0.5; }
	.breadcrumbs .current { color: var(--color-text); font-weight: 500; }

	.category-header {
		margin-bottom: 3rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}
	.category-badge {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: 0.75rem;
	}
	.category-header h1 {
		margin-bottom: 0.5rem;
	}
	.count {
		color: var(--color-text-subtle);
		font-size: 0.95rem;
	}

	.article-list {
		list-style: none;
		display: grid;
		gap: 1.5rem;
	}
	.article-card {
		padding: 1.75rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.75rem;
		transition: border-color 0.15s, transform 0.15s;
	}
	.article-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-1px);
	}
	.article-card h2 {
		font-size: 1.35rem;
		line-height: 1.3;
		margin-bottom: 0.6rem;
	}
	.article-card h2 a {
		color: var(--color-text);
		text-decoration: none;
	}
	.article-card h2 a:hover {
		color: var(--color-accent);
	}
	.desc {
		color: var(--color-text-muted);
		margin-bottom: 0.9rem;
	}
	.meta {
		font-size: 0.85rem;
		color: var(--color-text-subtle);
	}
	.meta strong { color: var(--color-text); font-weight: 600; }
	.meta .dot { opacity: 0.5; margin-inline: 0.4rem; }

	.empty-state {
		text-align: center;
		padding: 3rem 1rem;
		background: var(--color-surface);
		border: 1px dashed var(--color-border);
		border-radius: 0.75rem;
		color: var(--color-text-muted);
	}
	.empty-state .back-link {
		display: inline-block;
		margin-top: 1rem;
		color: var(--color-accent);
	}
</style>