---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ShareButtons from '../../components/ShareButtons.astro';
import CopyAttribution from '../../components/CopyAttribution.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';

export async function getStaticPaths() {
	const articles = await getCollection('articles', ({ data }) => !data.draft);
	return articles.map((article) => ({
		params: { slug: article.id },
		props: { article },
	}));
}

interface Props {
	article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content } = await render(article);

const formattedDate = article.data.publishDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const wordCount = article.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const categoryTitle = article.data.category
	.split('-')
	.map((w) => w.charAt(0).toUpperCase() + w.slice(1))
	.join(' ');

const categoryHref = "/" + article.data.category;
const backHref = categoryHref;
const backLabel = "← Back to " + categoryTitle;

const articleUrl = new URL(Astro.url.pathname, Astro.site || 'https://metronome.news').href;
---
<CopyAttribution />
<Layout
	title={article.data.title + " — Metronome News"}
	description={article.data.description}
	type="article"
	publishDate={article.data.publishDate}
	author={article.data.author}
>
	<article class="article-page">
		<nav class="breadcrumbs container" aria-label="Breadcrumb">
			<a href="/">Home</a>
			<span class="sep">›</span>
			<a href={categoryHref}>{categoryTitle}</a>
			<span class="sep">›</span>
			<span class="current">{article.data.title}</span>
		</nav>

		<header class="article-header container">
			<a href={categoryHref} class="category-link">{categoryTitle}</a>
			<h1 class="article-title">{article.data.title}</h1>
			<p class="article-description">{article.data.description}</p>

			{article.data.image && (
				<figure class="article-hero-image">
					<img
						src={article.data.image}
						alt={article.data.imageAlt || article.data.title}
						loading="eager"
					/>
				</figure>
			)}

			<div class="article-meta">
				<span>By <strong>{article.data.author}</strong></span>
				<span class="dot">·</span>
				<time datetime={article.data.publishDate.toISOString()}>{formattedDate}</time>
				<span class="dot">·</span>
				<span>{readingTime} min read</span>
			</div>

			{article.data.tags.length > 0 && (
				<div class="article-tags">
					{article.data.tags.map((tag) => (
						<span class="tag">#{tag}</span>
					))}
				</div>
			)}
		</header>

		<div class="article-layout container">
			<aside class="article-sidebar">
				<ShareButtons
					title={article.data.title}
					url={articleUrl}
					description={article.data.description}
				/>
			</aside>
			<div class="article-body">
				<Content />
				<div class="article-share-mobile">
					<ShareButtons
						title={article.data.title}
						url={articleUrl}
						description={article.data.description}
					/>
				</div>
			</div>
		</div>

	<div class="container">
			<RelatedArticles currentId={article.id} category={article.data.category} />
		</div>

		<footer class="article-footer container">
			<a href={backHref} class="back-link" id="backLink">{backLabel}</a>
		</footer>
	</article>
</Layout>

<style>
	.article-page {
		padding-block: 2rem 4rem;
	}
	.article-page .container {
		max-width: 780px;
	}
	.article-page .article-layout.container {
		max-width: 960px;
	}

	.breadcrumbs {
		font-size: 0.85rem;
		color: var(--color-text-subtle);
		margin-bottom: 2rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
	}
	.breadcrumbs a {
		color: var(--color-text-muted);
		text-decoration: none;
	}
	.breadcrumbs a:hover {
		color: var(--color-accent);
	}
	.breadcrumbs .sep {
		opacity: 0.4;
	}
	.breadcrumbs .current {
		color: var(--color-text);
		font-weight: 500;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 300px;
	}

	.article-header {
		margin-bottom: 2.5rem;
	}
	.article-hero-image {
		margin: 1.5rem 0 0 0;
		padding: 0;
	}
	.article-hero-image img {
		width: 100%;
		height: auto;
		max-height: 500px;
		object-fit: cover;
		border-radius: 12px;
		display: block;
	}
	.category-link {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: 1rem;
		text-decoration: none;
	}
	.category-link:hover {
		text-decoration: underline;
	}
	.article-title {
		font-size: clamp(1.75rem, 4vw, 2.85rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin-bottom: 1rem;
		color: var(--color-text);
		font-weight: 800;
	}
	.article-description {
		font-size: 1.15rem;
		line-height: 1.55;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
	}
	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		font-size: 0.9rem;
		color: var(--color-text-subtle);
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
		margin-top: 1.5rem;
	}
	.article-meta strong {
		color: var(--color-text);
		font-weight: 600;
	}
	.article-meta .dot {
		opacity: 0.5;
	}

	.article-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 1rem;
	}
	.tag {
		display: inline-block;
		padding: 0.25rem 0.7rem;
		font-size: 0.75rem;
		font-weight: 500;
		background: var(--color-surface-alt);
		color: var(--color-text-muted);
		border-radius: 2rem;
	}

	/* Layout: sidebar with share buttons + article body */
	.article-layout {
		display: grid;
		grid-template-columns: 140px 1fr;
		gap: 2.5rem;
		align-items: start;
	}

	.article-sidebar {
		position: sticky;
		top: 5rem;
	}

	.article-share-mobile {
		display: none;
	}

	@media (max-width: 900px) {
		.article-layout {
			grid-template-columns: 1fr;
			gap: 0;
		}
		.article-sidebar {
			display: none;
		}
		.article-share-mobile {
			display: block;
		}
	}

	.article-body {
		font-size: 1.075rem;
		line-height: 1.75;
		color: var(--color-text);
		min-width: 0;
	}
	.article-body :global(h2) {
		font-size: 1.75rem;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		line-height: 1.25;
	}
	.article-body :global(h3) {
		font-size: 1.35rem;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}
	.article-body :global(p) {
		margin-bottom: 1.25rem;
	}
	.article-body :global(ul),
	.article-body :global(ol) {
		margin: 1rem 0 1.5rem 1.5rem;
	}
	.article-body :global(li) {
		margin-bottom: 0.5rem;
	}
	.article-body :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.article-body :global(a:hover) {
		color: var(--color-accent-warm);
	}
	.article-body :global(strong) {
		font-weight: 700;
		color: var(--color-text);
	}
	.article-body :global(em) {
		font-style: italic;
	}
	.article-body :global(blockquote) {
		border-left: 3px solid var(--color-accent);
		padding-left: 1.25rem;
		margin: 1.5rem 0;
		font-style: italic;
		color: var(--color-text-muted);
	}
	.article-body :global(code) {
		background: var(--color-surface-alt);
		padding: 0.15rem 0.4rem;
		border-radius: 4px;
		font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
		font-size: 0.9em;
	}
	.article-body :global(pre) {
		background: var(--color-surface-alt);
		padding: 1rem;
		border-radius: 8px;
		overflow-x: auto;
		margin-bottom: 1.5rem;
	}
	.article-body :global(pre code) {
		background: transparent;
		padding: 0;
	}
	.article-body :global(img) {
		border-radius: 8px;
		margin-block: 1.5rem;
		max-width: 100%;
		height: auto;
	}
	.article-body :global(hr) {
		border: none;
		border-top: 1px solid var(--color-border);
		margin-block: 2.5rem;
	}

	.article-footer {
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-border);
	}
	.back-link {
		display: inline-block;
		color: var(--color-text-muted);
		font-weight: 500;
		text-decoration: none;
	}
	.back-link:hover {
		color: var(--color-accent);
	}
</style>

<script>
	function initBackLink() {
		const backLink = document.getElementById('backLink');
		if (!backLink) return;

		const referrer = document.referrer;
		const ourOrigin = window.location.origin;

		if (referrer && referrer.startsWith(ourOrigin)) {
			const referrerPath = new URL(referrer).pathname;
			const currentPath = window.location.pathname;

			if (referrerPath !== currentPath && referrerPath === '/') {
				backLink.textContent = '← Back to home';
				backLink.setAttribute('href', '/');
			}
		}
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initBackLink);
	} else {
		initBackLink();
	}
</script>