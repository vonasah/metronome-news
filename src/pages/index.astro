---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../content.config';

// Получаем все не-черновые статьи
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
allArticles.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Hero: первая featured-статья, или самая свежая, если нет featured
const heroArticle = allArticles.find((a) => a.data.featured) || allArticles[0];

// Все статьи кроме Hero
const articlesAfterHero = heroArticle
	? allArticles.filter((a) => a.id !== heroArticle.id)
	: [];

// Latest: 6 самых свежих статей (после Hero)
const latestArticles = articlesAfterHero.slice(0, 6);

// IDs статей которые уже показаны (Hero + Latest) — исключаем их из категорий
const shownIds = new Set<string>();
if (heroArticle) shownIds.add(heroArticle.id);
latestArticles.forEach((a) => shownIds.add(a.id));

// Для каждой категории — 3 свежие статьи которых ещё нет в Hero/Latest
const categorySections = CATEGORIES.map((cat) => {
	const articles = articlesAfterHero
		.filter((a) => a.data.category === cat && !shownIds.has(a.id))
		.slice(0, 3);
	return { category: cat, articles };
}).filter((section) => section.articles.length > 0);

// Precompute hero CSS class to avoid JSX parser quirks
const heroCardClass = heroArticle?.data.image ? "hero-card has-image" : "hero-card";
const heroHref = heroArticle ? "/article/" + heroArticle.id : "";

// Форматирование даты
function formatDate(date) {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	});
}

// Название категории с заглавной (e.g. "market-analysis" → "Market Analysis")
function prettyCategory(slug) {
	return slug
		.split('-')
		.map((w) => w.charAt(0).toUpperCase() + w.slice(1))
		.join(' ');
}
---

<Layout title="Metronome News — Crypto & Web3 journalism">
	<main class="home">
		{heroArticle ? (
			<section class="hero container">
				<a href={heroHref} class={heroCardClass}>
					<div class="hero-content">
						<div class="hero-tags">
							<span class="hero-category">{prettyCategory(heroArticle.data.category)}</span>
							{heroArticle.data.featured && (
								<span class="hero-featured-badge">★ Featured</span>
							)}
						</div>
						<h1 class="hero-title">{heroArticle.data.title}</h1>
						<p class="hero-description">{heroArticle.data.description}</p>
						<div class="hero-meta">
							<span>By <strong>{heroArticle.data.author}</strong></span>
							<span class="sep">·</span>
							<time datetime={heroArticle.data.publishDate.toISOString()}>
								{formatDate(heroArticle.data.publishDate)}
							</time>
						</div>
						<span class="hero-cta">Read article →</span>
					</div>
					{heroArticle.data.image && (
						<div class="hero-image">
							<img
								src={heroArticle.data.image}
								alt={heroArticle.data.imageAlt || heroArticle.data.title}
								loading="eager"
							/>
						</div>
					)}
				</a>
			</section>
		) : (
			<section class="empty-state container">
				<div class="empty-card">
					<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" class="empty-icon">
						<defs>
							<linearGradient id="emptyGrad" x1="0%" y1="0%" x2="100%" y2="100%">
								<stop offset="0%" stop-color="#3b82f6"/>
								<stop offset="100%" stop-color="#f97316"/>
							</linearGradient>
						</defs>
						<rect width="64" height="64" rx="12" fill="url(#emptyGrad)"/>
						<path d="M20 50 L44 50 L36 14 L28 14 Z" fill="none" stroke="white" stroke-width="3" stroke-linejoin="round"/>
						<line x1="32" y1="50" x2="22" y2="22" stroke="white" stroke-width="3" stroke-linecap="round"/>
						<circle cx="22" cy="22" r="3" fill="white"/>
					</svg>
					<h1>🎵 Tuning the rhythm...</h1>
					<p>First articles drop soon. Come back in a few days.</p>
				</div>
			</section>
		)}

		{latestArticles.length > 0 && (
			<section class="latest container">
				<div class="latest-header">
					<h2>Latest articles</h2>
				</div>

				<div class="latest-grid">
					{latestArticles.map((article) => {
						const href = "/article/" + article.id;
						return (
							<a href={href} class="latest-card">
								{article.data.image ? (
									<div class="latest-card-image">
										<img
											src={article.data.image}
											alt={article.data.imageAlt || article.data.title}
											loading="lazy"
										/>
									</div>
								) : (
									<div class="latest-card-image latest-card-image-placeholder"></div>
								)}
								<div class="latest-card-body">
									<div class="latest-card-category">{prettyCategory(article.data.category)}</div>
									<h3 class="latest-card-title">{article.data.title}</h3>
								</div>
							</a>
						);
					})}
				</div>
			</section>
		)}

		{categorySections.length > 0 && (
			<div class="category-sections container">
				{categorySections.map(({ category, articles }) => {
					const categoryHref = "/" + category;
					const categoryTitle = prettyCategory(category);
					return (
						<section class="cat-section">
							<div class="cat-section-header">
								<h2 class="cat-section-title">
									<a href={categoryHref}>{categoryTitle}</a>
								</h2>
								<a href={categoryHref} class="cat-section-link">See all →</a>
							</div>
							<div class="cat-section-accent"></div>

							<div class="article-grid">
								{articles.map((article) => {
									const href = "/article/" + article.id;
									return (
										<a href={href} class="article-card">
											{article.data.image && (
												<div class="card-image">
													<img
														src={article.data.image}
														alt={article.data.imageAlt || article.data.title}
														loading="lazy"
													/>
												</div>
											)}
											<div class="card-body">
												<div class="card-category">{categoryTitle}</div>
												<h3 class="card-title">{article.data.title}</h3>
												<p class="card-description">{article.data.description}</p>
												<div class="card-meta">
													<span>By {article.data.author}</span>
													<span class="dot">·</span>
													<time datetime={article.data.publishDate.toISOString()}>
														{formatDate(article.data.publishDate)}
													</time>
												</div>
											</div>
										</a>
									);
								})}
							</div>
						</section>
					);
				})}
			</div>
		)}
	</main>
</Layout>

<style>
	.home {
		padding-block: 2.5rem 4rem;
	}

	/* === HERO === */
	.hero {
		margin-bottom: 4rem;
	}
	.hero-card {
		display: block;
		padding: 3rem 2.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 1.25rem;
		text-decoration: none;
		color: inherit;
		position: relative;
		overflow: hidden;
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}
	.hero-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		background: var(--gradient-brand);
		z-index: 1;
	}
	.hero-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
		box-shadow: 0 12px 32px rgba(59, 130, 246, 0.12);
	}

	/* Hero with image: two-column layout */
	.hero-card.has-image {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2.5rem;
		align-items: center;
		padding: 2.5rem;
	}

	.hero-content {
		max-width: 780px;
	}

	.hero-image {
		border-radius: 0.75rem;
		overflow: hidden;
		aspect-ratio: 16 / 10;
		background: var(--color-surface-alt);
	}
	.hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s;
	}
	.hero-card:hover .hero-image img {
		transform: scale(1.02);
	}

	.hero-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		margin-bottom: 1.25rem;
	}
	.hero-category {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
	}
	.hero-featured-badge {
		display: inline-block;
		padding: 0.2rem 0.6rem;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		background: var(--gradient-brand);
		color: white;
		border-radius: 2rem;
	}

	.hero-title {
		font-size: clamp(1.75rem, 4.5vw, 3rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin-bottom: 1rem;
		color: var(--color-text);
		font-weight: 800;
	}

	.hero-description {
		font-size: clamp(1rem, 1.5vw, 1.2rem);
		line-height: 1.6;
		color: var(--color-text-muted);
		margin-bottom: 1.5rem;
	}

	.hero-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		font-size: 0.9rem;
		color: var(--color-text-subtle);
		margin-bottom: 1.75rem;
	}
	.hero-meta strong {
		color: var(--color-text);
		font-weight: 600;
	}
	.hero-meta .sep {
		opacity: 0.5;
	}

	.hero-cta {
		display: inline-block;
		color: var(--color-accent);
		font-weight: 600;
		font-size: 1rem;
		transition: transform 0.15s;
	}
	.hero-card:hover .hero-cta {
		transform: translateX(4px);
	}

	/* === LATEST (compact: photo + category + title only) === */
	.latest {
		margin-bottom: 4rem;
	}
	.latest-header {
		margin-bottom: 1.5rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--color-border);
	}
	.latest-header h2 {
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
		color: var(--color-text);
	}

	.latest-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.latest-card {
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.85rem;
		text-decoration: none;
		color: inherit;
		overflow: hidden;
		transition: border-color 0.15s, transform 0.15s;
	}
	.latest-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
	}

	.latest-card-image {
		aspect-ratio: 16 / 10;
		background: var(--color-surface-alt);
		overflow: hidden;
	}
	.latest-card-image-placeholder {
		background: var(--gradient-brand);
		opacity: 0.15;
	}
	.latest-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s;
	}
	.latest-card:hover .latest-card-image img {
		transform: scale(1.04);
	}

	.latest-card-body {
		padding: 1rem 1.1rem 1.1rem 1.1rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		flex: 1;
	}

	.latest-card-category {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.latest-card-title {
		font-size: 1rem;
		line-height: 1.35;
		color: var(--color-text);
		font-weight: 600;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* === CATEGORY SECTIONS === */
	.category-sections {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.cat-section {
		margin-block: 0;
	}

	.cat-section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-border);
		margin-bottom: 0.4rem;
	}

	.cat-section-title {
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}
	.cat-section-title a {
		color: var(--color-text);
		text-decoration: none;
		transition: color 0.15s;
	}
	.cat-section-title a:hover {
		color: var(--color-accent);
	}

	.cat-section-link {
		font-size: 0.9rem;
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 500;
		flex-shrink: 0;
		transition: transform 0.15s;
	}
	.cat-section-link:hover {
		transform: translateX(2px);
	}

	.cat-section-accent {
		width: 36px;
		height: 3px;
		background: var(--gradient-brand);
		border-radius: 2px;
		margin-bottom: 1.5rem;
	}

	/* === ARTICLE CARDS (used inside category sections) === */
	.article-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	.article-card {
		display: flex;
		flex-direction: column;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.85rem;
		text-decoration: none;
		color: inherit;
		overflow: hidden;
		transition: border-color 0.15s, transform 0.15s;
	}
	.article-card:hover {
		border-color: var(--color-accent);
		transform: translateY(-2px);
	}

	.card-image {
		aspect-ratio: 16 / 9;
		background: var(--color-surface-alt);
		overflow: hidden;
	}
	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.3s;
	}
	.article-card:hover .card-image img {
		transform: scale(1.04);
	}

	.card-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.card-category {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: 0.7rem;
	}

	.card-title {
		font-size: 1.15rem;
		line-height: 1.35;
		margin-bottom: 0.6rem;
		color: var(--color-text);
		font-weight: 700;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-description {
		font-size: 0.9rem;
		color: var(--color-text-muted);
		line-height: 1.5;
		margin-bottom: 1rem;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-meta {
		font-size: 0.8rem;
		color: var(--color-text-subtle);
		margin-top: auto;
	}
	.card-meta .dot {
		margin-inline: 0.35rem;
		opacity: 0.5;
	}

	/* === EMPTY STATE === */
	.empty-state {
		padding-block: 4rem 2rem;
	}
	.empty-card {
		text-align: center;
		padding: 3rem 2rem;
		background: var(--color-surface);
		border: 1px dashed var(--color-border);
		border-radius: 1rem;
	}
	.empty-icon {
		width: 64px;
		height: 64px;
		margin: 0 auto 1.25rem auto;
	}
	.empty-card h1 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}
	.empty-card p {
		color: var(--color-text-muted);
	}

	/* === RESPONSIVE === */
	@media (max-width: 900px) {
		.hero-card.has-image {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
		.hero-image {
			aspect-ratio: 16 / 9;
		}
		.latest-grid {
			grid-template-columns: repeat(2, 1fr);
		}
		.article-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* Mobile: compact cards + smaller hero */
	@media (max-width: 640px) {
		.home {
			padding-block: 1.5rem 3rem;
		}
		.hero {
			margin-bottom: 2.5rem;
		}
		.hero-card {
			padding: 1.5rem;
		}
		.hero-card.has-image {
			padding: 1.25rem;
			gap: 1rem;
		}
		.hero-image {
			aspect-ratio: 16 / 10;
			max-height: 220px;
		}
		.hero-title {
			font-size: 1.6rem;
		}
		.hero-description {
			font-size: 0.95rem;
		}

		.latest {
			margin-bottom: 2.5rem;
		}
		.latest-grid {
			grid-template-columns: 1fr;
			gap: 0.75rem;
		}
		.latest-card {
			flex-direction: row;
			min-height: 90px;
		}
		.latest-card-image {
			flex-shrink: 0;
			width: 110px;
			aspect-ratio: auto;
			height: auto;
		}
		.latest-card-body {
			padding: 0.75rem 1rem;
			gap: 0.3rem;
		}
		.latest-card-category {
			font-size: 0.65rem;
		}
		.latest-card-title {
			font-size: 0.92rem;
			-webkit-line-clamp: 2;
		}

		.category-sections {
			gap: 2rem;
		}
		.cat-section-title {
			font-size: 1.2rem;
		}
		.cat-section-link {
			font-size: 0.8rem;
		}

		/* Compact category cards: image on the left, text on the right */
		.article-grid {
			grid-template-columns: 1fr;
			gap: 0.75rem;
		}
		.article-card {
			flex-direction: row;
			min-height: 100px;
		}
		.card-image {
			flex-shrink: 0;
			width: 120px;
			aspect-ratio: auto;
			height: auto;
		}
		.card-body {
			padding: 0.85rem 1rem;
			gap: 0.3rem;
		}
		.card-category {
			font-size: 0.65rem;
			margin-bottom: 0.3rem;
		}
		.card-title {
			font-size: 0.95rem;
			-webkit-line-clamp: 2;
			margin-bottom: 0.3rem;
		}
		.card-description {
			display: none;
		}
		.card-meta {
			font-size: 0.7rem;
		}
	}
</style>
